{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-Command",
              "& \"$env:CLAUDE_PROJECT_DIR\\.claude\\scripts\\auto-setup.ps1\" -Quiet"
            ],
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-Command",
              "& \"$env:CLAUDE_PROJECT_DIR\\.claude\\scripts\\deploy-to-ninjatrader.ps1\""
            ],
            "timeout": 30
          }
        ]
      }
    ]
  }
}
